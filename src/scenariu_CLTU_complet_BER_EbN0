clc;
clear;
close all;

% SCENARIU CLTU
% Formare CLTU + BPSK + RRC + analiza in timp/frecventa + simulare BER in functie de Eb/N0 + detectie Start Sequence si Tail Sequence

rng(2);

% 1. PARAMETRI SCENARIU CLTU

% Structura CLTU
numCodewords = 4;                 % numar codewords
infoBitsPerCodeword = 56;         % biti utili / codeword
parityBitsPerCodeword = 7;        % biti paritate
fillerBitsPerCodeword = 1;        % bit filler
codewordLength = 64;              % lungime codeword

startSeq_hex = 'EB90';            % Start Sequence CLTU
tailSeq_hex  = 'C5C5C5C5C5C5C579';% Tail Sequence CLTU

% Modulare si filtrare
sps = 8;                          % samples per symbol / factor de interpolare
rolloff = 0.35;                   % factor rolloff RRC
span = 10;                        % span filtru RRC in simboluri

% BER
EbN0_dB = 0:1:10;                 % valori Eb/N0 in dB
numFramesBER = 500;               % numar CLTU-uri simulate pentru fiecare Eb/N0

%% Filtru Root Raised Cosine

rrcFilter = rcosdesign(rolloff, span, sps, "sqrt");

%% Secvente Start si Tail

startBits = hexToBits(startSeq_hex);
tailBits  = hexToBits(tailSeq_hex);


% 2. GENERARE CLTU PENTRU ANALIZA GRAFICA


% Date utile CLTU
numInfoBits = numCodewords * infoBitsPerCodeword;
infoBits = randi([0 1], numInfoBits, 1);

% Formare codewords simplificate de 64 biti
codedBits = [];

for cw = 1:numCodewords

    block56 = infoBits((cw-1)*infoBitsPerCodeword + 1 : cw*infoBitsPerCodeword);

    parity7 = generateSimpleParity7(block56);
    fillerBit = false;

    codeword64 = [logical(block56); parity7; fillerBit];

    codedBits = [codedBits; codeword64];

end

% Formare CLTU = Start Sequence + date codate + Tail Sequence
cltuBits = [startBits; codedBits; tailBits];

% Verificare Start/Tail in conditii ideale
startDetectedIdeal = isequal(cltuBits(1:length(startBits)), startBits);
tailDetectedIdeal = isequal(cltuBits(end-length(tailBits)+1:end), tailBits);

% Modulare BPSK
% 0 -> -1
% 1 -> +1
bpskSymbols = 2 * double(cltuBits) - 1;

% Filtrare Root Raised Cosine
tx_RRC = upfirdn(bpskSymbols, rrcFilter, sps, 1);


% 3. FIGURI PENTRU SCENARIUL CLTU

%% Figura 1 - Semnal CLTU BPSK filtrat RRC in domeniul timp

figure;
plot(tx_RRC(1:min(600, length(tx_RRC))));
grid on;
xlabel("Esantion");
ylabel("Amplitudine");
title("Semnal CLTU BPSK filtrat RRC in domeniul timp");

%% Figura 2 - Constelatie BPSK inainte de filtrare

figure;
scatter(real(bpskSymbols), zeros(size(bpskSymbols)), "o");
grid on;
xlabel("In-Phase");
ylabel("Quadrature");
title("Constelatie BPSK pentru CLTU inainte de filtrare");
xlim([-1.5 1.5]);
ylim([-1.5 1.5]);

%% Figura 3 - Primii biti demodulati in conditii ideale

rxBitsIdeal = bpskSymbols >= 0;

figure;
stem(rxBitsIdeal(1:min(120, length(rxBitsIdeal))), "filled");
grid on;
xlabel("Index bit");
ylabel("Valoare bit");
title("Primii biti demodulati din CLTU in conditii ideale");
ylim([-0.2 1.2]);

%% Figura 4 - Spectrul semnalului CLTU BPSK filtrat RRC

figure;
pwelch(tx_RRC, [], [], [], sps, "centered");
title("Spectrul semnalului CLTU BPSK filtrat RRC");


% 4. SIMULARE BER IN FUNCTIE DE Eb/N0 + DETECTIE START / TAIL

BER_CLTU = zeros(length(EbN0_dB), 1);
totalBitsBER = zeros(length(EbN0_dB), 1);
totalErrorsBER = zeros(length(EbN0_dB), 1);

StartDetectRate = zeros(length(EbN0_dB), 1);
TailDetectRate = zeros(length(EbN0_dB), 1);

fprintf("\n===== SIMULARE BER CLTU =====\n");

for idx = 1:length(EbN0_dB)

    ebn0 = EbN0_dB(idx);

    totalErrors = 0;
    totalBits = 0;

    startOK = 0;
    tailOK = 0;

    for frame = 1:numFramesBER

        %% Generare CLTU nou pentru fiecare cadru

        infoBitsBER = randi([0 1], numInfoBits, 1);

        codedBitsBER = [];

        for cw = 1:numCodewords

            block56 = infoBitsBER((cw-1)*infoBitsPerCodeword + 1 : cw*infoBitsPerCodeword);

            parity7 = generateSimpleParity7(block56);
            fillerBit = false;

            codeword64 = [logical(block56); parity7; fillerBit];

            codedBitsBER = [codedBitsBER; codeword64];

        end

        cltuBitsBER = [startBits; codedBitsBER; tailBits];

        % BPSK
        txSymbolsBER = 2 * double(cltuBitsBER) - 1;

        % Canal AWGN in functie de Eb/N0
        rxSymbolsBER = addAwgnEbN0(txSymbolsBER, ebn0);

        % Demodulare BPSK
        rxBitsBER = rxSymbolsBER >= 0;

        % BER
        bitErrors = sum(rxBitsBER ~= cltuBitsBER);

        totalErrors = totalErrors + bitErrors;
        totalBits = totalBits + length(cltuBitsBER);

        % Detectie Start Sequence
        rxStart = rxBitsBER(1:length(startBits));
        if isequal(rxStart, startBits)
            startOK = startOK + 1;
        end

        % Detectie Tail Sequence
        rxTail = rxBitsBER(end-length(tailBits)+1:end);
        if isequal(rxTail, tailBits)
            tailOK = tailOK + 1;
        end

    end

    BER_CLTU(idx) = totalErrors / totalBits;
    totalBitsBER(idx) = totalBits;
    totalErrorsBER(idx) = totalErrors;

    StartDetectRate(idx) = startOK / numFramesBER;
    TailDetectRate(idx) = tailOK / numFramesBER;

    fprintf("Eb/N0 = %2d dB, BER CLTU = %.6e, Start OK = %.2f, Tail OK = %.2f, Erori = %d, Biti testati = %d\n", ...
        ebn0, BER_CLTU(idx), StartDetectRate(idx), TailDetectRate(idx), totalErrors, totalBits);

end

%% Figura 5 - Curba BER CLTU

BER_plot = BER_CLTU;

for i = 1:length(BER_plot)
    if BER_plot(i) == 0
        BER_plot(i) = 1 / totalBitsBER(i);
    end
end

figure;
semilogy(EbN0_dB, BER_plot, "-o", "LineWidth", 1.5);
grid on;
xlabel("E_b/N_0 [dB]");
ylabel("BER");
title("Curba BER pentru scenariul CLTU");
ylim([1e-7 1]);
xlim([min(EbN0_dB) max(EbN0_dB)]);

%% Figura 6 - Rata detectie Start/Tail

figure;
plot(EbN0_dB, StartDetectRate, "-o", "LineWidth", 1.5);
hold on;
plot(EbN0_dB, TailDetectRate, "-s", "LineWidth", 1.5);
grid on;
xlabel("E_b/N_0 [dB]");
ylabel("Rata detectie");
title("Rata de detectie Start Sequence si Tail Sequence");
legend("Start Sequence", "Tail Sequence", "Location", "southeast");
ylim([0 1.05]);
xlim([min(EbN0_dB) max(EbN0_dB)]);

% 5. TABELE REZULTATE

