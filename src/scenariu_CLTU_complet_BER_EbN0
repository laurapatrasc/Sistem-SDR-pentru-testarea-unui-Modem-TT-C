T_parametri_CLTU = table(Parametru, Valoare);

T_BER_CLTU = table(EbN0_dB.', BER_CLTU, StartDetectRate, TailDetectRate, totalErrorsBER, totalBitsBER, ...
    'VariableNames', {'EbN0_dB', 'BER_CLTU', 'Rata_Start_Detectat', 'Rata_Tail_Detectat', 'Numar_Erori', 'Numar_Biti_Testati'});

disp(" ");
disp("Tabel parametri CLTU:");
disp(T_parametri_CLTU);

disp(" ");
disp("Tabel rezultate BER CLTU:");
disp(T_BER_CLTU);

