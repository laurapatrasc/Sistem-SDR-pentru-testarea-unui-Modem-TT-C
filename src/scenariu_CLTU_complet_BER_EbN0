% FUNCTII LOCALE


function bits = hexToBits(hexStr)

    hexStr = char(hexStr);
    bits = [];

    for i = 1:length(hexStr)
        value = hex2dec(hexStr(i));
        nibble = de2bi(value, 4, "left-msb").';
        bits = [bits; nibble];
    end

    bits = logical(bits);

end

function parity7 = generateSimpleParity7(block56)

    block56 = logical(block56);
    parity7 = false(7,1);

    for i = 1:7
        parity7(i) = mod(sum(block56(i:7:end)), 2);
    end

    parity7 = ~parity7;

end

function rx = addAwgnEbN0(tx, EbN0_dB)

    % Pentru BPSK normalizat:
    % simbolurile sunt -1 si +1, deci Eb = 1.
    % Eb/N0 este convertit din dB in valoare liniara.
    % Pentru zgomot real AWGN, varianta zgomotului este N0/2.

    EbN0_linear = 10^(EbN0_dB / 10);
    noiseVariance = 1 / (2 * EbN0_linear);

    noise = sqrt(noiseVariance) * randn(size(tx));

    rx = tx + noise;

end
